# ============================================================
# PROCUREMENT SPEND INTELLIGENCE PLATFORM
# Git Ignore Rules
#
# Excludes development artifacts, IDE settings, temporary files,
# Python cache files, and local database files that should not
# be committed to the repository.
# ============================================================


# ------------------------------------------------------------
# Visual Studio Code
# ------------------------------------------------------------

.vscode/


# ------------------------------------------------------------
# Python
# ------------------------------------------------------------

__pycache__/
*.py[cod]
*.pyo
*.pyd


# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------

.venv/
venv/
env/


# ------------------------------------------------------------
# Jupyter Notebooks
# ------------------------------------------------------------

.ipynb_checkpoints/


# ------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------

.DS_Store
Thumbs.db


# ------------------------------------------------------------
# DuckDB Temporary Files
# ------------------------------------------------------------

*.wal
*.tmp


# ------------------------------------------------------------
# Log Files
# ------------------------------------------------------------

*.log


# ------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------

.env
.env.*

# ---------------------------------------------------------
# DuckDB Database Temporary Files
# ---------------------------------------------------------

*.duckdb.wal
*.duckdb.tmp